{
	"name": "post-to-convex",
	"version": "0.0.1",
	"description": "A plugin to send data to a Convex powered backend",
	"author": "Isaac L. Félix",
	"license": "GPL-2.0-or-later",
	"main": "build/index.js",
	"scripts": {
		"build": "wp-scripts build --blocks-manifest",
		"format": "prettier --ignore-path ../../../.prettierignore --write \"src/**/*.{js,cjs,mjs,jsx,ts,tsx,css,scss,json}\" \"package.json\" \"composer.json\"",
		"format:check": "prettier --ignore-path ../../../.prettierignore --check \"src/**/*.{js,cjs,mjs,jsx,ts,tsx,css,scss,json}\" \"package.json\" \"composer.json\"",
		"lint:css": "wp-scripts lint-style",
		"lint:js": "eslint src",
		"packages-update": "wp-scripts packages-update",
		"plugin-zip": "wp-scripts plugin-zip",
		"start": "wp-scripts start --blocks-manifest"
	},
	"devDependencies": {
		"@wordpress/dom-ready": "^4.45.0",
		"@wordpress/scripts": "^32.1.0"
	}
}
