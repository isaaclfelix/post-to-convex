# Copy to ".env" and adjust values. Do not commit ".env".

# Host port for WordPress (http://localhost:<WP_PORT>)
WP_PORT=8080

# MySQL (used by the db service). WordPress reads the same credentials via
# WORDPRESS_DB_* in docker-compose.yml — keep MYSQL_* and WordPress in sync.
MYSQL_DATABASE=wordpress
MYSQL_USER=wordpress
MYSQL_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_root_me

# Optional: table prefix for wp-config (default wp_)
WORDPRESS_TABLE_PREFIX=wp_
