{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"lib": ["ES2022", "DOM", "DOM.Iterable"],
		"strict": true,
		"noEmit": true,
		"allowJs": true,
		"checkJs": false,
		"isolatedModules": true,
		"skipLibCheck": true,
		"resolveJsonModule": true
	},
	"include": ["wp-content/**/*.ts", "wp-content/**/*.tsx"],
	"exclude": [
		"**/node_modules/**",
		"**/build/**",
		"**/tmp/**",
		"**/vendor/**"
	]
}
